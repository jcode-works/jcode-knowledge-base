---
import "../styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Mimir",
  description = "Sovereign local RAG for confidential dossiers and AI agents.",
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
